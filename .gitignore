# Root gitignore

# Dependencies
node_modules/
**/node_modules/

# Environment files - NEVER commit these
.env
.env.local
.env.*.local
**/.env
**/.env.local

# Build outputs
dist/
.next/
out/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem
.vercel
*.tsbuildinfo
